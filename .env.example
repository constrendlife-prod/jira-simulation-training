# ────────────────────────────────────────────────────────────────────────────
# Jira - Simulation Program - Environment Configuration Example
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values
# ────────────────────────────────────────────────────────────────────────────

# ── Application Settings ──────────────────────────────────────────────────
APP_NAME=Jira Simulation Program
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# ── Admin Configuration ───────────────────────────────────────────────────
ADMIN_EMAILS=your_email@trendmicro.com

# ── Azure AD / MSAL Authentication ────────────────────────────────────────
MSAL_CLIENT_ID=your_client_id_here
MSAL_AUTHORITY=https://login.microsoftonline.com/your_tenant_id
MSAL_TENANT_ID=your_tenant_id_here

# ── OIDC Authentication (Alternative) ─────────────────────────────────────
AUTH_CLIENT_ID=your_client_id_here
AUTH_CLIENT_SECRET=your_client_secret_here
AUTH_REDIRECT_URI=http://localhost:8501/oauth2callback
AUTH_COOKIE_SECRET=generate_with_openssl_rand_hex_32
AUTH_SERVER_METADATA_URL=https://login.microsoftonline.com/your_tenant_id/v2.0/.well-known/openid-configuration

# ── Azure Cosmos DB ───────────────────────────────────────────────────────
COSMOSDB_ENDPOINT=https://your-cosmos-db.documents.azure.com:443/
COSMOSDB_KEY=your_cosmos_db_key_here
COSMOSDB_DATABASE_NAME=your_database_name
STORAGE_BACKEND=cosmosdb

# ── Jira Configuration ────────────────────────────────────────────────────
JIRA_URL=https://your-instance.atlassian.net
JIRA_EMAIL=your-email@trendmicro.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=PROJ

# ── Database (if using SQL instead of Cosmos) ─────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/jira_simulation
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=jira_simulation
# DB_USER=your_user
# DB_PASSWORD=your_password
